{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "cli": {
    "analytics": "5b0aef4d-0440-4ba7-8999-4dd4f4b5a163"
  },
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "SKY_B_Trans": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:application": {
          "strict": true
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",

          "options": {
            "outputPath": "dist/SKY_B_Trans",
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": "src/polyfills.ts",
            "tsConfig": "tsconfig.app.json",
            "allowedCommonJsDependencies": ["leaflet"],
            "assets": [
              "src/icon.ico",
              {
                "glob": "**/*",
                "input": "src/assets",
                "output": "/assets"
              }
            ],
            "styles": [
              "src/assets/css/preloader.min.css",
              "src/assets/css/bootstrap.min.css",
              "src/assets/css/icons.min.css",
              "src/assets/css/app.min.css",
              "src/assets/libs/@fullcalendar/core/main.min.css",
              "src/assets/libs/@fullcalendar/daygrid/main.min.css",
              "src/assets/libs/@fullcalendar/bootstrap/main.min.css",
              "src/assets/libs/@fullcalendar/timegrid/main.min.css",
              "src/assets/libs/datatables.net-bs4/css/dataTables.bootstrap4.min.css",
              "src/assets/libs/datatables.net-buttons-bs4/css/buttons.bootstrap4.min.css",
              "src/assets/libs/datatables.net-responsive-bs4/css/responsive.bootstrap4.min.css",
              "node_modules/leaflet/dist/leaflet.css",
              "node_modules/bootstrap/dist/css/bootstrap.min.css",
              "node_modules/ngx-toastr/toastr.css",
               "node_modules/leaflet-routing-machine/dist/leaflet-routing-machine.css"
            ],
            "scripts": [
              "src/assets/libs/jquery/jquery.min.js",
              "src/assets/libs/bootstrap/js/bootstrap.bundle.min.js",
              "src/assets/libs/metismenu/metisMenu.min.js",
              "src/assets/libs/simplebar/simplebar.min.js",
              "src/assets/libs/node-waves/waves.min.js",
              "src/assets/libs/feather-icons/feather.min.js",
              "src/assets/libs/pace-js/pace.min.js",
              "src/assets/js/pages/fontawesome.init.js",
              "src/assets/libs/echarts/echarts.min.js",
              "src/assets/libs/@fullcalendar/core/main.min.js",
              "src/assets/libs/@fullcalendar/daygrid/main.min.js",
              "src/assets/libs/@fullcalendar/bootstrap/main.min.js",
              "src/assets/libs/@fullcalendar/timegrid/main.min.js",
              "src/assets/libs/@fullcalendar/interaction/main.min.js",
              "src/assets/libs/datatables.net/js/jquery.dataTables.min.js",
              "src/assets/libs/datatables.net-bs4/js/dataTables.bootstrap4.min.js",
              "src/assets/libs/datatables.net-buttons/js/dataTables.buttons.min.js",
              "src/assets/libs/datatables.net-buttons-bs4/js/buttons.bootstrap4.min.js",
              "src/assets/libs/jszip/jszip.min.js",
              "src/assets/libs/pdfmake/build/pdfmake.min.js",
              "src/assets/libs/pdfmake/build/vfs_fonts.js",
              "src/assets/libs/datatables.net-buttons/js/buttons.html5.min.js",
              "src/assets/libs/datatables.net-buttons/js/buttons.print.min.js",
              "src/assets/libs/datatables.net-buttons/js/buttons.colVis.min.js",
              "src/assets/libs/datatables.net-responsive/js/dataTables.responsive.min.js",
              "src/assets/libs/datatables.net-responsive-bs4/js/responsive.bootstrap4.min.js",
              "src/assets/js/pages/datatables.init.js",
              "src/assets/js/app.js",
              "node_modules/bootstrap/dist/js/bootstrap.bundle.min.js",
              "node_modules/bootstrap/dist/js/bootstrap.js",
               "node_modules/leaflet/dist/leaflet.js",
               "node_modules/leaflet-routing-machine/dist/leaflet-routing-machine.js",
               "node_modules/leaflet-control-geocoder/dist/Control.Geocoder.js"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                 "maximumWarning": "15mb",
"maximumError": "20mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb",
                  "maximumError": "100kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "SKY_B_Trans:build:production"
            },
            "development": {
              "buildTarget": "SKY_B_Trans:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "buildTarget": "SKY_B_Trans:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "src/test.ts",
            "polyfills": "src/polyfills.ts",
            "tsConfig": "tsconfig.spec.json",
            "karmaConfig": "karma.conf.js",
            "assets": ["src/icon.ico", "src/assets"],
            "styles": [
              "@angular/material/prebuilt-themes/indigo-pink.css",
              "src/styles.css"
            ],
            "scripts": []
          }
        }
      }
    }
  }
}
